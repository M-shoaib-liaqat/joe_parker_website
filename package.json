{
  "name": "parker-electrical-solutions",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "react-snap",
    "preview": "vite preview",
    "server": "node --import tsx/esm server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\""
  },
  "reactSnap": {
    "source": "dist",
    "include": [
      "/",
      "/electrical-services-essex",
      "/electrical-contractors-essex",
      "/electrician-harlow",
      "/about",
      "/contact",
      "/areas",
      "/gallery",
      "/service/eicr-certificates",
      "/service/emergency-electrician",
      "/service/domestic-electrician",
      "/service/commercial-electrician",
      "/service/ev-charger-installation",
      "/service/house-rewiring",
      "/electrician-chelmsford",
      "/electrician-basildon",
      "/electrician-brentwood",
      "/electrician-east-london",
      "/eicr-certificate-essex",
      "/house-rewire-essex",
      "/consumer-unit-replacement-essex",
      "/ev-charging-essex",
      "/emergency-electrician-essex"
    ],
    "skipThirdPartyRequests": true
  },
  "dependencies": {
    "@emailjs/browser": "^4.2.0",
    "@getbrevo/brevo": "^3.0.1",
    "@google/generative-ai": "^0.21.0",
    "@sendgrid/mail": "^8.1.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "lucide-react": "^0.563.0",
    "nodemailer": "^6.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^6.4.22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.5.33",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.0.0",
    "postcss": "^8.5.6",
    "react-snap": "^1.23.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.17.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
